# ========================================================
# .ENV TEMPLATE - fluxohub Admin Monorepo
# AVISO: NUNCA commite o arquivo real (.env) no repositório
# ========================================================

# [Banco de Dados e Cache]
# URL de conexão do PostgreSQL (Exemplo Neon/Supabase)
DATABASE_URL="postgresql://user:pass@host:5432/fluxohub?schema=public"

# URL do Redis para Rate Limiting e Blacklist
REDIS_URL="redis://localhost:6379"

# [Autenticação e Criptografia]
# Assinatura forte do JsonWebToken (Access Token de 15m)
JWT_SECRET="GERAR_NO_MINIMO_32_CARACTERES_COM_ENTROPIA"

# Assinatura dos Cookies HttpOnly no Fastify
COOKIE_SECRET="CHAVE_LONGA_PARA_ASSINATURA_DE_COOKIES_123456789"

# Chave Mestre de Criptografia do AES-256-GCM. 
# Deve ser EXATAMENTE 32 bytes (256 bits) convertida para Base64.
# Rode `node -e "console.log(crypto.randomBytes(32).toString('base64'))"` para gerar uma.
MASTER_ENCRYPTION_KEY="BASE64_GERADA_AQUI"
